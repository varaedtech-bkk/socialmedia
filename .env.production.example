# .env.production.example
# Copy this file to .env.production and fill in real values.
# For local development, use .env (do not commit secrets).

# ============================================
# Core
# ============================================
DATABASE_URL='postgresql://user:password@host:5432/dbname'
SESSION_SECRET='generate-a-long-random-secret-at-least-32-chars'
CLIENT_URL='https://yourdomain.com'
BASE_URL='https://yourdomain.com'
NODE_ENV='production'

# ============================================
# Admin & Notifications
# ============================================
SUPER_ADMIN_EMAIL='admin@yourdomain.com'
DEFAULT_COMPANY_SLUG='default-company'
NOTIFICATION_FROM_EMAIL='noreply@yourdomain.com'
RESEND_API_KEY='re_...'

# SMTP (if not using Resend)
SMTP_HOST='smtp.example.com'
SMTP_PORT='587'
SMTP_SECURE='false'
SMTP_USER='user@example.com'
SMTP_PASS='password'
SMTP_FROM='noreply@yourdomain.com'
MAIL_FROM='noreply@yourdomain.com'

# ============================================
# Billing (Stripe)
# ============================================
STRIPE_SECRET_KEY='sk_live_...'
STRIPE_ADVANCE_PRICE_ID='price_...'
STRIPE_WEBHOOK_SECRET='whsec_...'
STRIPE_ACCESS_REQUEST_ADVANCE_PRICE_ID='price_...'
STRIPE_ACCESS_REQUEST_BASIC_PRICE_ID='price_...'
STRIPE_REQUIRE_SUPER_ADMIN_APPROVAL='false'

# ============================================
# Trial & AI
# ============================================
TRIAL_DAYS='7'
OPENROUTER_API_KEY='sk-or-v1-...'   # optional platform-level reference; runtime AI is BYOK gated
OPENROUTER_MODEL='openai/gpt-4o-mini'
OPENROUTER_APP_TITLE='MultiSocial Studio'

# ============================================
# Social Platforms OAuth
# ============================================
# Facebook / Meta
META_PAGE_APP_ID='123456789'
META_PAGE_APP_SECRET='...'
META_REDIRECT_URI='https://yourdomain.com/api/facebook/auth/callback'

# WhatsApp Business (OAuth/app credentials in current code)
WHATSAPP_APP_ID='123456789'
WHATSAPP_APP_SECRET='...'
WHATSAPP_REDIRECT_URI='https://yourdomain.com/api/auth/whatsapp/callback'
# WhatsApp Cloud API (for full messaging flow verification)
WHATSAPP_CLOUD_ACCESS_TOKEN='EAA...'
WHATSAPP_CLOUD_PHONE_NUMBER_ID='123456789'
WHATSAPP_WEBHOOK_VERIFY_TOKEN='random_verify_token'

# LinkedIn
LINKEDIN_CLIENT_ID='...'
LINKEDIN_CLIENT_SECRET='...'
LINKEDIN_REDIRECT_URI='https://yourdomain.com/api/auth/linkedin/callback'
# Optional page-specific overrides
LINKEDIN_PAGE_CLIENT_ID='...'
LINKEDIN_PAGE_CLIENT_SECRET='...'
LINKEDIN_PAGE_REDIRECT_URI='https://yourdomain.com/api/auth/linkedin/page/callback'

# Instagram (Instagram Login)
INSTAGRAM_APP_ID='...'
INSTAGRAM_APP_SECRET='...'
INSTAGRAM_REDIRECT_URI='https://yourdomain.com/api/auth/instagram/callback'

# Google
GOOGLE_CLIENT_ID='...'
GOOGLE_CLIENT_SECRET='...'
GOOGLE_REDIRECT_URI='https://yourdomain.com/api/auth/callback/google'

# ============================================
# Telegram Agent
# ============================================
TELEGRAM_BOT_TOKEN='...'
TELEGRAM_WEBHOOK_SECRET='...'
TELEGRAM_LINK_SECRET='...'   # optional, falls back to SESSION_SECRET
TELEGRAM_DEFAULT_USER_ID='2' # fallback if no mapping found

# ============================================
# n8n Integration (optional)
# ============================================
N8N_ENABLED='false'
N8N_WEBHOOK_URL='https://n8n.example.com/webhook'
N8N_WEBHOOK_AUTH_TOKEN='...'
N8N_WEBHOOK_AUTH_HEADER='Authorization'
N8N_WEBHOOK_TIMEOUT_MS='30000'
